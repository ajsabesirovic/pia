              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"dobavljac_id\": 1,\n  \"stavke\": [ { \"lek_id\": 1, \"kolicina\": 0, \"cena_po_komadu\": 120.00 } ]\n}" },
            "url": { "raw": "{{base_url}}/narudzbenice", "host": ["{{base_url}}"], "path": ["narudzbenice"] }
          }
        },
        {
          "name": "Create order (nepostojeci dobavljac) - TC-09",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [

{
  "info": {
    "name": "IS Farmacy - PIA API",
    "description": "Postman kolekcija za testiranje Laravel REST API-ja koji koristi Angular SPA.\n\nDva procesa:\n1) Prijava korisnika (validacija unosa)\n2) Obrada narudzbenice (slozeniji poslovni proces)\n\nKako koristiti:\n- Izaberi okruzenje 'IS Farmacy - Local'.\n- Prvo pokreni 'Auth / Login (valid)' - test skripta automatski snima {{token}}.\n- Zatim 'Narudzbenice / Create order' - snima {{narudzbenica_id}}.\n- Ostali zahtevi koriste te promenljive.\n\nKolekcija sadrzi i NEGATIVNE zahteve (nevalidni unosi) za test plan.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (valid) - TC-01",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Vraca token', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.test('Vraca korisnika', () => pm.expect(body.user).to.be.an('object'));",
                  "if (body.token) { pm.collectionVariables.set('token', body.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin.apoteka1@apoteke.rs\",\n  \"password\": \"password\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "description": "Validan unos (admin apoteke A iz seed-a). Ocekuje 200 + token. Ovaj nalog ne mora slati apoteka_id pri kreiranju narudzbenice."
          }
        },
        {
          "name": "Login (pogresna lozinka) - TC-04",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Poruka o gresci na email polju', () => pm.expect(pm.response.json().errors.email).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin.apoteka1@apoteke.rs\",\n  \"password\": \"pogresna\"\n}" },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Login (nevalidan email format) - TC-02",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Greska na polju email', () => pm.expect(pm.response.json().errors.email).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin.apoteka1-apoteke.rs\",\n  \"password\": \"password\"\n}" },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Login (prazna polja) - TC-03",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "const e = pm.response.json().errors;",
                  "pm.test('Greska na email i password', () => { pm.expect(e.email).to.exist; pm.expect(e.password).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"\",\n  \"password\": \"\"\n}" },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Me (token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Vraca korisnika', () => pm.expect(pm.response.json().user).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        },
        {
          "name": "Me (bez tokena -> 401) - TC-05",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        }
      ]
    },

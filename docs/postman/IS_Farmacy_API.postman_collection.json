            ],
            "body": { "mode": "raw", "raw": "{\n  \"dobavljac_id\": 999999,\n  \"stavke\": [ { \"lek_id\": 1, \"kolicina\": 5, \"cena_po_komadu\": 120.00 } ]\n}" },
            "url": { "raw": "{{base_url}}/narudzbenice", "host": ["{{base_url}}"], "path": ["narudzbenice"] }
          }
        },

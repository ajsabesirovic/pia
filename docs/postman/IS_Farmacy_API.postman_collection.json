    {
      "name": "Narudzbenice",
      "item": [
        {
          "name": "Index (lista, paginacija)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/narudzbenice?status=&page=1",
              "host": ["{{base_url}}"],
              "path": ["narudzbenice"],
              "query": [
                { "key": "status", "value": "" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Create order (valid) - TC-06",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('Status nacrt', () => pm.expect(b.status).to.eql('nacrt'));",
                  "pm.test('Ukupna vrednost izracunata', () => pm.expect(Number(b.ukupna_vrednost)).to.be.above(0));",
                  "if (b.id) { pm.collectionVariables.set('narudzbenica_id', b.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dobavljac_id\": 1,\n  \"napomena\": \"Test narudzbenica\",\n  \"stavke\": [\n    { \"lek_id\": 1, \"kolicina\": 5, \"cena_po_komadu\": 120.00 }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/narudzbenice", "host": ["{{base_url}}"], "path": ["narudzbenice"] },
            "description": "Centralni admin mora dodati i \"apoteka_id\". Admin apoteke ne salje apoteka_id (uzima se njegova)."
          }
        },
        {
          "name": "Create order (prazne stavke) - TC-07",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Greska na stavke', () => pm.expect(pm.response.json().errors.stavke).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"dobavljac_id\": 1,\n  \"stavke\": []\n}" },
            "url": { "raw": "{{base_url}}/narudzbenice", "host": ["{{base_url}}"], "path": ["narudzbenice"] }
          }
        },
        {
          "name": "Create order (kolicina = 0) - TC-08",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",

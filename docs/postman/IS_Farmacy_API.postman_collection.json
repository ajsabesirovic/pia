            "url": { "raw": "{{base_url}}/narudzbenice/{{narudzbenica_id}}/otkazi", "host": ["{{base_url}}"], "path": ["narudzbenice", "{{narudzbenica_id}}", "otkazi"] },
            "description": "Pokreni POSLE 'Oznaci isporuceno'. Isporucenu narudzbenicu nije moguce otkazati -> 422."
          }
        }
